    "name": "version",
    "type": "input-text",
    "label": "版本",
    "default": "1.0"
  },
  {
    "name": "noSkip",
    "type": "checkbox",
    "label": "关闭自动拾取"
  },
  {
    "name": "noEat",
    "type": "checkbox",
    "label": "关闭自动吃药"
  },
  {
    "name": "logmode",
    "type": "checkbox",
    "label": "不生成详细的日志"
  },
  {
    "name": "worldName",
    "type": "select",
    "label": "当前所在世界\n选择当前录制所在的世界，用于坐标识别",
