    "options": [
      "提瓦特大陆 (Teyvat)",
      "层岩巨渊 (TheChasm)",
      "渊下宫 (Enkanomiya)",
      "旧日之海 (SeaOfBygoneEras)",
      "远古圣山 (AncientSacredMountain)"
    ]
  }
