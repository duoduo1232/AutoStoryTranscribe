    "name": "version",
    "type": "input-text",
    "label": "版本",
    "default": "1.0"
  },
  {
    "name": "noSkip",
    "type": "checkbox",
    "label": "关闭自动拾取"
  },
  {
    "name": "noEat",
    "type": "checkbox",
    "label": "关闭自动吃药"
  },
  {
    "name": "logmode",
    "type": "checkbox",
    "label": "不生成详细的日志"
  }
