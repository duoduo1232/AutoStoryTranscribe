  },
  {
    "name": "questLocation",
    "type": "input-text",
    "label": "任务地点\n任务所在地点，用于组织文件夹",
    "default": "默认"
  },
  {
    "name": "keyDialogue",
    "type": "input-text",
    "label": "保存路径+对话界面",
    "default": "F7"
  },
  {
    "name": "keyFight",
    "type": "input-text",
    "label": "保存路径+战斗界面",
    "default": "F8"
  },
  {
    "name": "keyPause",
    "type": "input-text",
    "label": "保存路径+暂停界面",
    "default": "F9"
  },
  {
    "name": "keySave",
    "type": "input-text",
    "label": "只保存路径界面",
